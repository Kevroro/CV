  <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>

  <script>
    lucide.createIcons();

    const sections = document.querySelectorAll('.section');
    const navPills = document.querySelectorAll('.nav-pill');
    const bottomTabs = document.querySelectorAll('.bottom-tab');

    function setActiveButtons(id){
      navPills.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.target === id);
      });

      bottomTabs.forEach(btn => {
        btn.classList.toggle('active', btn.dataset.target === id);
      });
    }

    function showSection(id){
      sections.forEach(section => section.classList.remove('active'));
      const activeSection = document.getElementById(id);
      if(activeSection){
        activeSection.classList.add('active');
        activeSection.scrollIntoView({ behavior:'smooth', block:'start' });
      }
      setActiveButtons(id);

      if(id === 'skills'){
        animateSkills();
      }
    }

    navPills.forEach(btn => {
      btn.addEventListener('click', () => showSection(btn.dataset.target));
    });

    bottomTabs.forEach(btn => {
      btn.addEventListener('click', () => showSection(btn.dataset.target));
    });

    document.querySelectorAll('.nav-go').forEach(btn => {
      btn.addEventListener('click', () => {});
    });

    function animateSkills(){
      const fills = document.querySelectorAll('#skills .skill-fill');
      fills.forEach(fill => {
        fill.style.width = '0';
      });

      setTimeout(() => {
        fills.forEach(fill => {
          fill.style.width = fill.dataset.width;
        });
      }, 180);
    }

    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if(entry.isIntersecting){
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: .12 });

    document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));

    function generateQR(){
      const qrContainer = document.getElementById('qrcode');
      qrContainer.innerHTML = '';

      const currentURL = window.location.href;
      const isLocal = currentURL.startsWith('file:');

      const qrValue = isLocal
        ? 'mailto:kevin.roldan.rodriguez@gmail.com?subject=He%20visto%20tu%20CV'
        : currentURL;

      new QRCode(qrContainer, {
        text: qrValue,
        width: 180,
        height: 180,
        correctLevel: QRCode.CorrectLevel.H
      });
    }

    function detectPhoto(){
      const hero = document.getElementById('heroPhoto');
      const img = new Image();
      img.src = 'kevin-photo.jpg';
      img.onload = () => hero.classList.remove('no-photo');
      img.onerror = () => hero.classList.add('no-photo');
    }

    window.addEventListener('load', () => {
      detectPhoto();
      generateQR();
      showSection('experiencia');
      animateSkills();
    });
  </script>
